# LLM Provider: "ollama" | "groq" | "huggingface"
LLM_PROVIDER=ollama

# Ollama (fully local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Groq (free tier — get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace (free tier — get token at https://huggingface.co/settings/tokens)
HF_API_TOKEN=

# Embeddings (always local, no API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Infrastructure
REDIS_URL=redis://localhost:6379
CHROMA_HOST=localhost
CHROMA_PORT=8000

# App
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=20
